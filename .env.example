# These will be automatically created by Neon Launchpad (https://neon.new).
# You will also need to 
DATABASE_URL=
DATABASE_URL_POOLER=

# Better Auth (required for login/signup persistence)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google sign-in (optional; email/password works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Transactional email via Resend free tier (optional in dev; links log to console)
RESEND_API_KEY=
EMAIL_FROM=ClothBooks <onboarding@resend.dev>

# Set to true once auth DB tables are migrated and you want /app gated
VITE_REQUIRE_AUTH=false

# TanStack Router/Query devtools (off by default — FAB can block voucher Save)
# VITE_ENABLE_DEVTOOLS=true
