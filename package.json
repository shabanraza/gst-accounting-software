{
  "name": "gst-accounting-software",
  "description": "Modern Indian GST accounting, inventory, and business operations SaaS",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "./scripts/with-node-runtime.sh vite dev --port 3000",
    "generate-routes": "./scripts/with-node-runtime.sh tsr generate",
    "build": "./scripts/with-node-runtime.sh vite build",
    "preview": "./scripts/with-node-runtime.sh vite preview",
    "test": "./scripts/with-node-runtime.sh vitest run",
    "lint": "./scripts/with-node-runtime.sh eslint",
    "format": "./scripts/with-node-runtime.sh prettier --write . && ./scripts/with-node-runtime.sh eslint --fix",
    "check": "./scripts/with-node-runtime.sh prettier --check .",
    "deploy": "bun run build && ./scripts/with-node-runtime.sh wrangler deploy",
    "db:generate": "./scripts/with-node-runtime.sh drizzle-kit generate",
    "db:migrate": "./scripts/with-node-runtime.sh drizzle-kit migrate",
    "db:apply-0007": "bun scripts/apply-migration-0007.ts",
    "db:apply-0008": "bun scripts/apply-migration-0008.ts",
    "db:apply-0009": "bun scripts/apply-migration-0009.ts",
    "db:reconcile": "bun scripts/reconcile-drizzle-migrations.ts",
    "db:push": "./scripts/with-node-runtime.sh drizzle-kit push",
    "db:pull": "./scripts/with-node-runtime.sh drizzle-kit pull",
    "db:studio": "./scripts/with-node-runtime.sh drizzle-kit studio"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@faker-js/faker": "^10.5.0",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@neondatabase/serverless": "^1.1.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/query-db-collection": "latest",
    "@tanstack/react-db": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-store": "latest",
    "@tanstack/react-table": "latest",
    "@tanstack/router-plugin": "^1.168.19",
    "@tanstack/store": "latest",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@trpc/tanstack-react-query": "^11.18.0",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "decimal.js": "^10.6.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "3.8.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite-plugin-neon-new": "^0.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/devtools-event-client": "latest",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@tanstack/router-cli": "^1.167.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/decimal.js": "^7.4.3",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.5",
    "jsdom": "^28.1.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
