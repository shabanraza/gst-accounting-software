{
  "expo": {
    "name": "GST Books",
    "slug": "gst-books",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gstbooks",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gstbooks.mobile"
    },
    "android": {
      "package": "com.gstbooks.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GST Books to attach bill photos for OCR review.",
          "cameraPermission": "Allow GST Books to capture purchase bills."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000001"
      }
    }
  }
}
